{
  "metadata": {
    "id": "scenario_3",
    "title": "Temporal Workflow Hijacking — Batch Export Data Exfiltration",
    "description": "An attacker who already has compromised PostHog credentials manipulates Temporal workflows to exfiltrate data. The attack uses batch export workflows to route data to attacker-controlled destinations. Temporal logs reveal unusual workflow patterns: unauthorized workflow starts, suspicious activity/workflow context, abnormal retry patterns, and data routing to external destinations via the Kafka→ClickHouse log pipeline.",
    "source_type": "temporal_workflow",
    "dataset_ref": "synthetic — based on PostHog Temporal logger fields",
    "mitre_techniques": ["T1537", "T1078", "T1070.004"]
  },
