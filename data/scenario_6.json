    "id": "scenario_6",
    "title": "Exception Spike & Middleware Anomalies — API Exploitation Attempt",
    "description": "An attacker probes PostHog's API for injection vulnerabilities. The exception capture system records a spike in unusual exceptions (SQL injection attempts, parameter manipulation, deserialization errors). Simultaneously, Django middleware logs show suspicious request patterns: forged headers, rapid requests from a single IP, and requests to undocumented internal endpoints.",
    "source_type": "exception_middleware",
    "dataset_ref": "synthetic — based on PostHog exceptions_capture + django-structlog middleware fields",
    "mitre_techniques": ["T1190", "T1059.001", "T1046"]
  },
