{
  "metadata": {
    "id": "scenario_8",
    "title": "Prometheus Metrics Anomalies — Credential Stuffing & Cryptomining",
    "description": "An attacker performs a credential-stuffing attack against PostHog's API, then escalates to data exfiltration and deploys a cryptominer sidecar. Prometheus metrics reveal the attack through quantitative anomalies: sudden spike in HTTP 401/403 responses, abnormal outbound network bytes, Celery task queue explosion, ClickHouse query duration spike, and CPU/memory/disk anomalies on a compromised pod.",
    "source_type": "prometheus_metrics",
    "dataset_ref": "synthetic — based on PostHog Prometheus/django-prometheus metrics",
    "mitre_techniques": ["T1110.004", "T1496", "T1041", "T1053.005"]
  },
