  "metadata": {
    "id": "scenario_4",
    "title": "Celery Task Queue Injection — Unauthorized Task Execution",
    "description": "An attacker gains access to the Celery task queue via a compromised Redis broker and injects malicious tasks. The logs reveal unauthorized task types from unknown workers, rapid task failures with retries, and sensitive data operations (user deletion, data export, permission changes) executed from non-scheduled origins.",
    "source_type": "celery_task",
    "dataset_ref": "synthetic — based on PostHog Celery/django-structlog fields",
    "mitre_techniques": ["T1053.005", "T1059", "T1531"]
  },
