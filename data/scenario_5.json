  "metadata": {
    "id": "scenario_5",
    "title": "OpenTelemetry Trace Anomalies — Unauthorized ClickHouse Data Extraction",
    "description": "An attacker with access to PostHog's internal API exploits it to run unauthorized ClickHouse queries extracting sensitive user data. OpenTelemetry distributed traces reveal the attack chain: unusual spans showing direct ClickHouse access bypassing normal query paths, abnormal query durations indicating bulk data extraction, queries targeting sensitive tables (person, events with PII), and cross-service trace propagation from an unexpected origin.",
    "source_type": "otel_trace",
    "dataset_ref": "synthetic — based on PostHog OTel instrumentation + ClickHouse tracing fields",
    "mitre_techniques": ["T1213", "T1530", "T1071.001"]
  },
