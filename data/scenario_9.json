    "id": "scenario_9",
    "title": "MCP Service Exploitation — AI Tool Abuse for Data Extraction",
    "description": "An attacker discovers PostHog's MCP endpoint and abuses it to extract sensitive analytics data. The MCP RequestLogger captures unauthorized access attempts, session hijacking via stolen tokens, rapid-fire tool calls to extract person data, requests with abnormally long durations indicating heavy data extraction, and requests from unexpected origins not matching registered AI assistants.",
    "source_type": "mcp_service",
    "dataset_ref": "synthetic — based on PostHog MCP RequestLogger fields",
    "mitre_techniques": ["T1530", "T1550.001", "T1119", "T1071.001"]
  },
