{
  "metadata": {
    "id": "scenario_10",
    "title": "HogQL Injection — Query Manipulation for Data Exfiltration",
    "description": "An attacker with API access discovers a HogQL injection vulnerability in a custom insight endpoint. They probe with malformed queries to trigger parser errors, then craft injection payloads that bypass input sanitization to extract data from sensitive tables (person, person_distinct_id). The attack progresses from reconnaissance (error-based probing) through exploitation (injected UNION SELECT) to exfiltration (bulk person data extraction via crafted HogQL expressions). Logged via PostHog's structlog query execution and ClickHouse query_log_archive.",
    "source_type": "hogql_query",
    "dataset_ref": "synthetic — based on PostHog HogQL parser (posthog/hogql/parser.py), QueryTags (posthog/clickhouse/query_tagging.py), and query_log_archive schema",
    "mitre_techniques": ["T1190", "T1059.009", "T1005", "T1530"]
  },
